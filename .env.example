# ---------------------------------------------------------------------------
# Qwen Cloud (REQUIRED)
# ---------------------------------------------------------------------------
# Get your key at https://dashscope-intl.aliyuncs.com
DASHSCOPE_API_KEY="sk-..."

# Optional: override the default model
# QWEN_MODEL="qwen3.7-plus"

# Optional: override the DashScope API endpoint (default: international)
# QWEN_BASE_URL="https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
# For mainland China, use:
# QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# Optional: enable thinking mode for complex tool orchestration (default: true)
# ENABLE_THINKING=true

# ---------------------------------------------------------------------------
# Alibaba Cloud (required for "real" mode; ignored in "demo" mode)
# ---------------------------------------------------------------------------
# Credentials are managed via `aliyun configure` and stored in ~/.aliyun/config.json
# The agent's scripts use the aliyun CLI which reads credentials automatically.
#
# To configure: aliyun configure
# To use a named profile: aliyun configure --profile blueteam
#
# Optional: override the auto-discovered region
# ALIBABA_REGION=""           # Auto-discovered from `aliyun configure`

# ---------------------------------------------------------------------------
# Agent behavior
# ---------------------------------------------------------------------------
# demo = read from fixture JSON files (default, no Alibaba Cloud needed)
# real = call live Alibaba Cloud APIs (requires credentials above)
# SECURITY_CENTER_MODE=demo

# Maximum agent-loop iterations before stopping (default: 20)
# MAX_TOOL_ROUNDS=20

# ---------------------------------------------------------------------------
# MCP servers (optional — GRC integrations)
# ---------------------------------------------------------------------------
# Path to MCP server config file (default: .mcp.json in project root)
# MCP_CONFIG_PATH=.mcp.json

# ---------------------------------------------------------------------------
# Memory & Embeddings (optional)
# ---------------------------------------------------------------------------
# The agent stores incident embeddings in a local SQLite/libSQL database
# at data/blueteam.db (auto-created, no config needed).
#
# Optional: enable Turso cloud sync for cross-device memory
# TURSO_DATABASE_URL=""
#
# Embeddings use the same DASHSCOPE_API_KEY above (text-embedding-v3 model).
# In demo mode (SECURITY_CENTER_MODE=demo), embeddings fall back to
# deterministic hash-based vectors — no API calls needed.

# ---------------------------------------------------------------------------
# Autonomous SOC daemon (optional)
# ---------------------------------------------------------------------------
# Run with: python blueteam.py --daemon --interval 60
# The daemon continuously monitors for new alerts and escalates high-severity.
# DAEMON_INTERVAL is set via CLI flag (--interval), not env var.
