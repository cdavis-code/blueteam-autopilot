# ---------------------------------------------------------------------------
# Qwen Cloud (REQUIRED)
# ---------------------------------------------------------------------------
# Get your key at https://dashscope-intl.aliyuncs.com
DASHSCOPE_API_KEY="sk-..."

# Optional: override the default model
# QWEN_MODEL="qwen3.7-plus"

# Optional: enable thinking mode for complex tool orchestration (default: true)
# ENABLE_THINKING=true

# ---------------------------------------------------------------------------
# Alibaba Cloud (required for "real" mode; ignored in "demo" mode)
# ---------------------------------------------------------------------------
# Credentials are managed via `aliyun configure` and stored in ~/.aliyun/config.json
# The agent's scripts use the aliyun CLI which reads credentials automatically.
#
# To configure: aliyun configure
# To use a named profile: aliyun configure --profile blueteam
#
# Optional: override the auto-discovered region
# ALIBABA_REGION=""           # Auto-discovered from `aliyun configure`

# ---------------------------------------------------------------------------
# Agent behavior
# ---------------------------------------------------------------------------
# demo = read from fixture JSON files (default, no Alibaba Cloud needed)
# real = call live Alibaba Cloud APIs (requires credentials above)
# SECURITY_CENTER_MODE=demo

# Maximum agent-loop iterations before stopping (default: 20)
# MAX_TOOL_ROUNDS=20
